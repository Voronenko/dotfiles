#!/usr/bin/env bash

LOW=50500
HIGH=51000
RANGE=$((HIGH - LOW + 1))


print_result() {
  local project_id="$1"
  local wide="$2"

  local sha1_hex
  sha1_hex=$(printf "%s" "$project_id" | sha1sum | awk '{print $1}')

  local sha1_int=$((16#$sha1_hex))
  local port=$((sha1_int % RANGE + LOW))

  if [[ "$wide" == "true" ]]; then

    echo "Deterministic project-id → port generator"
    echo "Formula: sha1 → int → % ($HIGH-$LOW+1) + $LOW"
    echo

    echo "Project ID: $project_id"
    echo "SHA1:       $sha1_hex"
    echo "Port:       $port"
  else
    echo "$port"
  fi
}

# ---- Non-interactive mode ----
if [[ -n "${1:-}" ]]; then
  project_id="$1"
  wide="false"

  # Check for --wide flag
  if [[ "$1" == "--wide" ]]; then
    wide="true"
    shift
    project_id="${1:-}"
  elif [[ "$2" == "--wide" ]]; then
    wide="true"
  fi

  if [[ -n "$project_id" ]]; then
    print_result "$project_id" "$wide"
    exit 0
  fi
fi

echo "Press Ctrl+C to exit."
echo

# ---- Interactive mode ----
while true; do
  read -rp "Enter project identifier: " project_id
  [[ -z "$project_id" ]] && continue
  print_result "$project_id" "true"
  echo
done
