#!/usr/bin/env bash

#
# This script is a wrapper for the defuddle binary.
# It first checks if defuddle is in the PATH (excluding this script).
# If not, it falls back to a known nvm location.
# # https://github.com/kepano/defuddle
#

export DEFAULT_NODEJS_BIN="$HOME/.nvm/versions/node/v22.14.0/bin/"

# If defuddle exists in PATH (excluding this script), use it
REAL_BIN=$(command -v defuddle | grep -v "$(realpath "$0")")

if [ -n "$REAL_BIN" ]; then
  exec "$REAL_BIN" "$@"
fi

# Fallback to known nvm location
NVM_BIN="$DEFAULT_NODEJS_BIN/defuddle"

if [ -x "$NVM_BIN" ]; then
  exec "$NVM_BIN" "$@"
fi

echo "defuddle not found in PATH or fallback location" >&2
exit 1
