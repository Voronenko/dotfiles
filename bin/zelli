#!/bin/bash

# zelli - Zellij session manager with layout validation
# Usage: zelli <session_name> [clear]
#   <session_name> - Name of the session (must match a layout in ~/.config/zellij/layouts/)
#   clear           - Optional: kill the session if it exists

set -e

# Check if at least one argument is provided
if [ $# -lt 1 ]; then
    echo "Usage: zelli <session_name> [clear]"
    echo ""
    echo "Arguments:"
    echo "  <session_name>  Name of the session (must have a corresponding .kdl layout)"
    echo "  clear           Optional: kill the session if it exists"
    echo ""
    echo "Examples:"
    echo "  zelli myproject       # Join or create session 'myproject'"
    echo "  zelli myproject clear # Kill session 'myproject' if it exists"
    exit 1
fi

SESSION_NAME="$1"
ACTION="${2:-}"
LAYOUT_PATH="$HOME/.config/zellij/layouts/${SESSION_NAME}.kdl"

# Validate that the layout exists
if [ ! -f "$LAYOUT_PATH" ]; then
    echo "Error: Layout file not found: $LAYOUT_PATH"
    echo ""
    echo "Available layouts:"
    find "$HOME/.config/zellij/layouts" -name "*.kdl" -type f 2>/dev/null | sed 's|.*/||; s|\.kdl$||' | sort | while read -r layout; do
        echo "  - $layout"
    done
    exit 1
fi

# Check if the session exists
SESSION_EXISTS=$(zellij list-sessions --no-formatting 2>/dev/null | grep -c "^${SESSION_NAME} " || true)

# Handle clear action
if [ "$ACTION" = "clear" ]; then
    if [ "$SESSION_EXISTS" -gt 0 ]; then
        echo "Killing session: $SESSION_NAME"
        zellij delete-session "$SESSION_NAME" --force
    else
        echo "Session '$SESSION_NAME' does not exist, nothing to clear."
    fi
    exit 0
fi

# Normal mode: join if exists, otherwise create new
if [ "$SESSION_EXISTS" -gt 0 ]; then
    echo "Joining existing session: $SESSION_NAME"
    gnome-terminal -- zellij attach "$SESSION_NAME" &
else
    echo "Creating new session: $SESSION_NAME"
    gnome-terminal -- zellij -n "$SESSION_NAME" -s "$SESSION_NAME" --layout "$SESSION_NAME" &
fi
