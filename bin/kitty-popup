#!/usr/bin/env bash

set -e

# Detect title
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    title=$(basename "$(git rev-parse --show-toplevel)")
else
    title=$(basename "$PWD")
fi

# Fallback just in case
title=${title:-shell}

# Run kitty in background
kitty --title "$title" >/dev/null 2>&1 &
