#!/usr/bin/env bash
# kitty-tmux-shim: Intercepts tmux commands from Claude Code and
# translates them to Kitty remote control equivalents.
#
# This script is placed on PATH ahead of real tmux so that any
# invocation of `tmux <subcommand>` hits this shim first.

set -uo pipefail

STATE_DIR="${KITTY_TMUX_SHIM_STATE:?KITTY_TMUX_SHIM_STATE not set}"
SHIM_DIR="${KITTY_TMUX_SHIM_DIR:?KITTY_TMUX_SHIM_DIR not set}"

if date '+%N' 2>/dev/null | grep -q '^[0-9]'; then
    _SHIM_DATE_FMT='%H:%M:%S.%N'
else
    _SHIM_DATE_FMT='%H:%M:%S'
fi

log_debug() {
    if [ "${KITTY_TMUX_SHIM_DEBUG:-}" = "1" ]; then
        echo "[$(date "+$_SHIM_DATE_FMT")] $*" >> "${STATE_DIR}/shim.log"
    fi
}

kitty_run() {
    if [ "${KITTY_TMUX_SHIM_DEBUG:-}" = "1" ]; then
        kitten "$@" 2>>"${STATE_DIR}/shim.log"
    else
        kitten "$@" 2>/dev/null
    fi
}

log_debug "tmux called with: $*"

validate_pane_key() {
    case "$1" in
        ''|*[!0-9]*)
            log_debug "ERROR: invalid pane key: '$1'"
            return 1
            ;;
    esac
}

alloc_pane_id() {
    local lockdir="${STATE_DIR}/next_id.lock"
    local attempts=0
    while ! mkdir "$lockdir" 2>/dev/null; do
        attempts=$((attempts + 1))
        if [ "$attempts" -ge 50 ] && [ -d "$lockdir" ]; then
            local lock_pid
            lock_pid=$(cat "$lockdir/pid" 2>/dev/null || echo "")
            if [ -z "$lock_pid" ] || ! kill -0 "$lock_pid" 2>/dev/null; then
                log_debug "WARNING: removing stale lock (PID '${lock_pid}' dead or missing)"
                rm -f "$lockdir/pid"
                rmdir "$lockdir" 2>/dev/null || true
            fi
        fi
        if [ "$attempts" -gt 100 ]; then
            log_debug "ERROR: could not acquire next_id lock"
            return 1
        fi
        sleep 0.1 2>/dev/null || sleep 1
    done

    echo "$$" > "$lockdir/pid"

    if [ ! -f "${STATE_DIR}/next_id" ]; then
        echo "1" > "${STATE_DIR}/next_id"
    fi

    local current
    current=$(cat "${STATE_DIR}/next_id")
    case "$current" in
        ''|*[!0-9]*)
            log_debug "ERROR: corrupt next_id value: '${current}', resetting to 1"
            current=1
            ;;
    esac
    echo "$((current + 1))" > "${STATE_DIR}/next_id"
    rm -f "$lockdir/pid"
    rmdir "$lockdir"

    echo "%${current}"
}

snapshot_env() {
    local env_file="${STATE_DIR}/parent.env"
    if [ -f "$env_file" ]; then
        return 0
    fi
    local tmp_file="${env_file}.$$"
    export -p | grep -v \
        -e ' KITTY_WINDOW_ID=' \
        -e ' TMUX_PANE=' \
        -e ' _=' \
        -e ' SHLVL=' \
        -e ' OLDPWD=' \
        -e ' PWD=' \
        > "$tmp_file" || true
    mv -n "$tmp_file" "$env_file" 2>/dev/null || rm -f "$tmp_file"
}

wait_for_ready() {
    local pane_key="$1"
    local max_wait=50
    local i=0
    while [ ! -f "${STATE_DIR}/${pane_key}.ready" ]; do
        i=$((i + 1))
        if [ "$i" -ge "$max_wait" ]; then
            log_debug "ERROR: timed out waiting for pane ${pane_key} to become ready"
            return 1
        fi
        sleep 0.1 2>/dev/null || sleep 1
    done
}

wait_for_named() {
    local pane_key="$1"
    local max_wait=30
    local i=0
    while [ ! -f "${STATE_DIR}/${pane_key}.named" ]; do
        i=$((i + 1))
        if [ "$i" -ge "$max_wait" ]; then
            log_debug "wait_for_named: timed out for pane ${pane_key}"
            break
        fi
        sleep 0.1 2>/dev/null || sleep 1
    done
}

serialize_command() {
    local result=""
    local arg
    for arg in "$@"; do
        if [ -n "$result" ]; then
            result="$result "
        fi
        result="$result$(printf '%q' "$arg")"
    done
    echo "$result"
}

kitty_get_window_id() {
    local pane_key="$1"
    local kitty_id_file="${STATE_DIR}/${pane_key}.kitty_id"
    if [ -f "$kitty_id_file" ]; then
        cat "$kitty_id_file" 2>/dev/null
    fi
}

ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        -L|-S)
            shift 2 || shift
            ;;
        -L*|-S*)
            shift
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done
set -- "${ARGS[@]+"${ARGS[@]}"}"

if [ $# -eq 0 ]; then
    log_debug "no subcommand, forwarding to real tmux or failing"
    if [ -n "${KITTY_TMUX_SHIM_REAL_TMUX:-}" ] && [ -x "$KITTY_TMUX_SHIM_REAL_TMUX" ]; then
        exec "$KITTY_TMUX_SHIM_REAL_TMUX"
    fi
    exit 0
fi

CMD="$1"
shift

case "$CMD" in

-V)
    echo "tmux 3.6a"
    exit 0
    ;;

display-message)
    dm_target=""
    dm_format=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -t) dm_target="${2:-}"; shift 2 || shift ;;
            -p) shift ;;
            *)  dm_format="$1"; shift ;;
        esac
    done

    case "$dm_format" in
        '#{pane_id}')
            echo "${TMUX_PANE:-"%0"}"
            ;;
        '#{session_name}:#{window_index}')
            echo "main:0"
            ;;
        '#{session_name}')
            echo "main"
            ;;
        '#{window_index}')
            echo "0"
            ;;
        *)
            log_debug "display-message: unhandled format '$dm_format'"
            echo "main:0"
            ;;
    esac
    exit 0
    ;;

split-window)
    sw_target=""
    sw_direction="hsplit"
    sw_size=""
    sw_print=false
    sw_format=""
    sw_command=()
    while [ $# -gt 0 ]; do
        case "$1" in
            -t) sw_target="${2:-}"; shift 2 || shift ;;
            -h) sw_direction="hsplit"; shift ;;
            -v) sw_direction="vsplit"; shift ;;
            -l) sw_size="${2:-}"; shift 2 || shift ;;
            -P) sw_print=true; shift ;;
            -F) sw_format="${2:-}"; shift 2 || shift ;;
            -d) shift ;;
            --)
                shift
                sw_command=("$@")
                break
                ;;
            *)
                sw_command=("$@")
                break
                ;;
        esac
    done

    NEW_PANE_ID=$(alloc_pane_id) || { log_debug "split-window: alloc failed"; exit 1; }
    PANE_KEY="${NEW_PANE_ID#%}"
    validate_pane_key "$PANE_KEY" || { log_debug "split-window: invalid pane key"; exit 1; }

    echo "${KITTY_WINDOW_ID:-0}" > "${STATE_DIR}/${PANE_KEY}.group"

    for _gf in "${STATE_DIR}"/*.group; do
        [ -f "$_gf" ] || continue
        _gk="${_gf##*/}"; _gk="${_gk%.group}"
        [ "$_gk" = "$PANE_KEY" ] && continue
        [ "$(cat "$_gf" 2>/dev/null)" = "${KITTY_WINDOW_ID:-0}" ] || continue
        _pp="${STATE_DIR}/${_gk}.pid"
        [ -f "$_pp" ] || continue
        _pd=$(cat "$_pp" 2>/dev/null)
        if [ -n "$_pd" ] && kill -0 "$_pd" 2>/dev/null; then
            sw_direction="vsplit"
            break
        fi
    done

    log_debug "split-window: creating pane ${NEW_PANE_ID} direction=${sw_direction}"

    snapshot_env

    kitty_args=(
        @ launch
        --type=window
        --location="$sw_direction"
        --keep-focus
        --cwd=current
        --allow-remote-control
    )

    KITTY_RESPONSE=$(kitty_run "${kitty_args[@]}" -- "${SHIM_DIR}/bin/kitty-window-wrapper" "$STATE_DIR" "$SHIM_DIR" "$NEW_PANE_ID")
    KITTY_RC=$?

    if [ $KITTY_RC -ne 0 ] || [ -z "$KITTY_RESPONSE" ]; then
        log_debug "split-window: kitten @ launch failed (rc=$KITTY_RC, response='$KITTY_RESPONSE')"
        kitty_args=(
            @ launch
            --type=window
            --location="$sw_direction"
            --keep-focus
            --cwd=current
        )
        KITTY_RESPONSE=$(kitty_run "${kitty_args[@]}" -- "${SHIM_DIR}/bin/kitty-window-wrapper" "$STATE_DIR" "$SHIM_DIR" "$NEW_PANE_ID")
        KITTY_RC=$?
    fi

    if [ $KITTY_RC -ne 0 ] || [ -z "$KITTY_RESPONSE" ]; then
        log_debug "split-window: all launch attempts failed"
        exit 1
    fi

    KITTY_WID=$(echo "$KITTY_RESPONSE" | tr -d '[:space:]')
    log_debug "split-window: kitty window id=${KITTY_WID}"

    if ! wait_for_ready "$PANE_KEY"; then
        log_debug "split-window: pane ${NEW_PANE_ID} failed to become ready"
        exit 1
    fi

    log_debug "split-window: pane ${NEW_PANE_ID} ready (kitty_id=${KITTY_WID})"

    if [ ${#sw_command[@]} -gt 0 ]; then
        local_fifo="${STATE_DIR}/${PANE_KEY}.fifo"
        if [ -p "$local_fifo" ]; then
            serialize_command "${sw_command[@]}" > "$local_fifo"
            log_debug "split-window: delivered command to ${NEW_PANE_ID}"
        fi
        wait_for_named "$PANE_KEY"
    fi

    if [ "$sw_print" = true ]; then
        echo "$NEW_PANE_ID"
    fi
    exit 0
    ;;

send-keys)
    sk_target=""
    sk_keys=()
    sk_send_sigint=false
    while [ $# -gt 0 ]; do
        case "$1" in
            -t) sk_target="${2:-}"; shift 2 || shift ;;
            C-c)
                sk_send_sigint=true
                shift
                ;;
            Enter|C-m)
                shift
                ;;
            *)
                sk_keys+=("$1")
                shift
                ;;
        esac
    done

    if [ -z "$sk_target" ]; then
        log_debug "send-keys: no target specified, ignoring"
        exit 0
    fi

    PANE_KEY="${sk_target#%}"
    validate_pane_key "$PANE_KEY" || { log_debug "send-keys: invalid pane key"; exit 1; }

    if [ "$sk_send_sigint" = true ]; then
        PID_FILE="${STATE_DIR}/${PANE_KEY}.pid"
        if [ -f "$PID_FILE" ]; then
            pid=$(cat "$PID_FILE")
            if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                kill -INT "$pid" 2>/dev/null || true
                log_debug "send-keys: sent SIGINT to PID ${pid}"
            fi
        fi
        if [ ${#sk_keys[@]} -eq 0 ]; then
            exit 0
        fi
    fi

    FIFO_PATH="${STATE_DIR}/${PANE_KEY}.fifo"
    COMMAND_TEXT="${sk_keys[*]}"
    log_debug "send-keys: target=${sk_target} command='${COMMAND_TEXT}'"

    if [ -p "$FIFO_PATH" ]; then
        echo "$COMMAND_TEXT" > "$FIFO_PATH"
        log_debug "send-keys: delivered to FIFO"
        wait_for_named "$PANE_KEY"
    else
        KITTY_WID=$(kitty_get_window_id "$PANE_KEY")
        if [ -n "$KITTY_WID" ]; then
            log_debug "send-keys: FIFO gone, falling back to send-text (kitty_id=${KITTY_WID})"
            kitten @ send-text --match="id:${KITTY_WID}" "${COMMAND_TEXT}"$'\n' 2>/dev/null || true
        else
            log_debug "send-keys: no FIFO and no kitty_id for ${sk_target}"
        fi
    fi
    exit 0
    ;;

kill-pane)
    kp_target=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -t) kp_target="${2:-}"; shift 2 || shift ;;
            -a) shift ;;
            *) shift ;;
        esac
    done

    if [ -z "$kp_target" ]; then
        log_debug "kill-pane: no target"
        exit 0
    fi

    PANE_KEY="${kp_target#%}"
    validate_pane_key "$PANE_KEY" || { log_debug "kill-pane: invalid pane key"; exit 1; }
    log_debug "kill-pane: killing ${kp_target}"

    PID_FILE="${STATE_DIR}/${PANE_KEY}.pid"
    if [ -f "$PID_FILE" ]; then
        pid=$(cat "$PID_FILE")
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            kill -TERM -- -"$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
            log_debug "kill-pane: sent SIGTERM to PID ${pid} (process group attempted)"
        fi
    fi

    KITTY_WID=$(kitty_get_window_id "$PANE_KEY")
    if [ -n "$KITTY_WID" ]; then
        kitten @ close-window --match="id:${KITTY_WID}" 2>/dev/null || true
        log_debug "kill-pane: closed kitty window ${KITTY_WID}"
    fi

    rm -f "${STATE_DIR}/${PANE_KEY}.pid"
    rm -f "${STATE_DIR}/${PANE_KEY}.kitty_id"
    rm -f "${STATE_DIR}/${PANE_KEY}.fifo"
    rm -f "${STATE_DIR}/${PANE_KEY}.ready"
    rm -f "${STATE_DIR}/${PANE_KEY}.group"
    rm -f "${STATE_DIR}/${PANE_KEY}.named"

    exit 0
    ;;

list-panes)
    while [ $# -gt 0 ]; do
        case "$1" in
            -t) shift 2 || shift ;;
            -F) shift 2 || shift ;;
            *) shift ;;
        esac
    done

    echo "%0"

    for pidfile in "${STATE_DIR}"/*.pid; do
        [ -f "$pidfile" ] || continue
        basename="${pidfile##*/}"
        pane_key="${basename%.pid}"
        [ "$pane_key" = "0" ] && continue
        pid=$(cat "$pidfile" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            echo "%${pane_key}"
        fi
    done
    exit 0
    ;;

has-session)
    hs_target=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -t) hs_target="${2:-}"; shift 2 || shift ;;
            *) shift ;;
        esac
    done

    if [ -z "$hs_target" ]; then
        exit 1
    fi

    if grep -qxF "$hs_target" "${STATE_DIR}/sessions" 2>/dev/null; then
        exit 0
    else
        exit 1
    fi
    ;;

new-session)
    ns_name=""
    ns_detach=false
    ns_print=false
    ns_format=""
    ns_command=()
    while [ $# -gt 0 ]; do
        case "$1" in
            -d) ns_detach=true; shift ;;
            -s) ns_name="${2:-}"; shift 2 || shift ;;
            -n) shift 2 || shift ;;
            -x|-y) shift 2 || shift ;;
            -P) ns_print=true; shift ;;
            -F) ns_format="${2:-}"; shift 2 || shift ;;
            --)
                shift
                ns_command=("$@")
                break
                ;;
            *)
                ns_command+=("$1")
                shift
                ;;
        esac
    done

    if [ -n "$ns_name" ]; then
        if ! grep -qxF "$ns_name" "${STATE_DIR}/sessions" 2>/dev/null; then
            echo "$ns_name" >> "${STATE_DIR}/sessions"
        fi
        log_debug "new-session: registered session '${ns_name}'"
    fi

    if [ "$ns_print" = true ]; then
        echo "${TMUX_PANE:-"%0"}"
    fi
    exit 0
    ;;

new-window)
    nw_target=""
    nw_name=""
    nw_print=false
    nw_format=""
    nw_command=()
    while [ $# -gt 0 ]; do
        case "$1" in
            -t) nw_target="${2:-}"; shift 2 || shift ;;
            -n) nw_name="${2:-}"; shift 2 || shift ;;
            -P) nw_print=true; shift ;;
            -F) nw_format="${2:-}"; shift 2 || shift ;;
            -d) shift ;;
            --)
                shift
                nw_command=("$@")
                break
                ;;
            *)
                nw_command+=("$1")
                shift
                ;;
        esac
    done

    NEW_PANE_ID=$(alloc_pane_id) || { log_debug "new-window: alloc failed"; exit 1; }
    PANE_KEY="${NEW_PANE_ID#%}"
    validate_pane_key "$PANE_KEY" || { log_debug "new-window: invalid pane key"; exit 1; }

    log_debug "new-window: creating pane ${NEW_PANE_ID} name=${nw_name}"

    echo "${KITTY_WINDOW_ID:-0}" > "${STATE_DIR}/${PANE_KEY}.group"

    snapshot_env

    kitty_args=(
        @ launch
        --type=tab
        --keep-focus
        --cwd=current
        --allow-remote-control
    )
    if [ -n "$nw_name" ]; then
        kitty_args+=(--title="$nw_name")
    fi

    KITTY_RESPONSE=$(kitty_run "${kitty_args[@]}" -- "${SHIM_DIR}/bin/kitty-window-wrapper" "$STATE_DIR" "$SHIM_DIR" "$NEW_PANE_ID")
    KITTY_RC=$?

    if [ $KITTY_RC -ne 0 ] || [ -z "$KITTY_RESPONSE" ]; then
        kitty_args=(
            @ launch
            --type=tab
            --keep-focus
            --cwd=current
        )
        if [ -n "$nw_name" ]; then
            kitty_args+=(--title="$nw_name")
        fi
        KITTY_RESPONSE=$(kitty_run "${kitty_args[@]}" -- "${SHIM_DIR}/bin/kitty-window-wrapper" "$STATE_DIR" "$SHIM_DIR" "$NEW_PANE_ID")
    fi

    if ! wait_for_ready "$PANE_KEY"; then
        log_debug "new-window: pane ${NEW_PANE_ID} failed to become ready"
        exit 1
    fi

    if [ ${#nw_command[@]} -gt 0 ]; then
        local_fifo="${STATE_DIR}/${PANE_KEY}.fifo"
        if [ -p "$local_fifo" ]; then
            serialize_command "${nw_command[@]}" > "$local_fifo"
        fi
        wait_for_named "$PANE_KEY"
    fi

    if [ "$nw_print" = true ]; then
        echo "$NEW_PANE_ID"
    fi
    exit 0
    ;;

list-windows)
    while [ $# -gt 0 ]; do
        case "$1" in
            -t) shift 2 || shift ;;
            -F) shift 2 || shift ;;
            *) shift ;;
        esac
    done
    echo "main"
    exit 0
    ;;

select-pane)
    sp_target=""
    sp_title=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -t) sp_target="${2:-}"; shift 2 || shift ;;
            -T) sp_title="${2:-}"; shift 2 || shift ;;
            -P) shift 2 || shift ;;
            *) shift ;;
        esac
    done
    if [ -n "$sp_title" ] && [ -n "$sp_target" ]; then
        PANE_KEY="${sp_target#%}"
        KITTY_WID=$(kitty_get_window_id "$PANE_KEY")
        if [ -n "$KITTY_WID" ]; then
            kitten @ set-window-title --match="id:${KITTY_WID}" "$sp_title" 2>/dev/null || true
            log_debug "select-pane: set title '${sp_title}' on kitty window ${KITTY_WID}"
        fi
    elif [ -n "$sp_target" ]; then
        PANE_KEY="${sp_target#%}"
        KITTY_WID=$(kitty_get_window_id "$PANE_KEY")
        if [ -n "$KITTY_WID" ]; then
            kitten @ focus-window --match="id:${KITTY_WID}" 2>/dev/null || true
            log_debug "select-pane: focused kitty window ${KITTY_WID}"
        fi
    fi
    exit 0
    ;;

set-option|setw|set-window-option)
    log_debug "no-op: $CMD $*"
    exit 0
    ;;

select-layout|resize-pane|break-pane|join-pane|set|bind-key|unbind-key|source-file|rename-session|rename-window|move-window|swap-pane|swap-window|pipe-pane|capture-pane|save-buffer|delete-buffer|wait-for|refresh-client)
    log_debug "no-op: $CMD $*"
    exit 0
    ;;

*)
    log_debug "UNHANDLED: $CMD $*"
    if [ -n "${KITTY_TMUX_SHIM_REAL_TMUX:-}" ] && [ -x "$KITTY_TMUX_SHIM_REAL_TMUX" ]; then
        log_debug "forwarding to real tmux: $CMD $*"
        exec "$KITTY_TMUX_SHIM_REAL_TMUX" "$CMD" "$@"
    fi
    exit 0
    ;;

esac
